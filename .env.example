# ============================================================
# Dice&Soup 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 警告：.env 文件包含敏感信息，永远不要提交到 Git！
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
# SQLite 模式（开发默认）
DATABASE_URL=file:./data/dice-soup.db

# PostgreSQL 模式（生产推荐）
# DATABASE_URL=postgresql://user:password@localhost:5432/dice_soup

# ── 管理员初始密码 ───────────────────────────────────────────
# 首次启动时写入数据库，之后可删除此行
# 首次登录后系统会强制要求修改密码
ADMIN_INITIAL_PASSWORD=liuyuhao

# ── OneBot / NapCat ─────────────────────────────────────────
# 反向 WebSocket 监听端口（NapCat 连接此端口）
ONEBOT_WS_PORT=6700

# OneBot 鉴权 Token（首次启动若未设置则自动生成并打印到日志）
# 将此值填入 NapCat 的 反向WebSocket -> access_token 配置
ONEBOT_ACCESS_TOKEN=mysecrettoken123

# ── 服务器 ──────────────────────────────────────────────────
# HTTP 服务端口（管理后台 + API）
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# JWT 签名密钥（管理员 Web 登录用，请使用随机长字符串）
JWT_SECRET=abcdef1234567890abcdef1234567890

# ── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs/dice-soup.log

# ── LLM API Keys（敏感，勿提交）────────────────────────────
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=

# ── 环境标识 ────────────────────────────────────────────────
NODE_ENV=development
