# ===================================================
# .claudeignore — dice-soup monorepo
# 技术栈：pnpm workspaces / Fastify / Vue3+Vite /
#         Drizzle ORM / NapCat / Vitest / Docker
# ===================================================

# ────────────────────────────────────────
# 依赖目录
# ────────────────────────────────────────
node_modules/
apps/*/node_modules/
packages/*/node_modules/

# ────────────────────────────────────────
# 构建产物
# ────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# Vite 缓存（web-admin）
.vite/
apps/web-admin/.vite/

# 压缩产物
*.min.js
*.min.css
*.js.map
*.css.map

# 原生绑定（@napi-rs/canvas 编译产物）
*.node

# ────────────────────────────────────────
# 运行时缓存
# ────────────────────────────────────────
.cache/
.turbo/
tmp/
temp/

# ────────────────────────────────────────
# 数据库 & ORM
# ────────────────────────────────────────
# SQLite 数据文件（dev 本地数据，非代码）
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Drizzle 迁移 snapshot（自动生成，体积随版本增长）
# 保留：drizzle/*.sql（迁移 SQL 本身对理解 schema 演化很重要）
drizzle/meta/

# ────────────────────────────────────────
# 日志
# ────────────────────────────────────────
*.log
logs/
server-logs/

# ────────────────────────────────────────
# Docker 数据卷（持久化运行时数据，非代码）
# 注意：docker/ 目录本身保留，是源码
# ────────────────────────────────────────
postgres-data/
redis-data/
napcat-data/
napcat-config/

# ────────────────────────────────────────
# Git
# ────────────────────────────────────────
.git/

# ────────────────────────────────────────
# 锁文件
# ────────────────────────────────────────
# pnpm-lock.yaml 建议保留：
# Claude 可从中了解精确版本与 workspace 依赖关系
package-lock.json
yarn.lock
bun.lock

# ────────────────────────────────────────
# 环境变量与敏感配置
# ────────────────────────────────────────
.env
.env.*
!.env.example

# ────────────────────────────────────────
# 媒体 / 字体 / 二进制
# ────────────────────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.mp4
*.mp3
*.woff
*.woff2
*.ttf
*.eot
*.tgz
*.zip
*.tar.gz
*.7z

# SVG 策略（重要）：
# card-renderer 的 SVG 模板是源码 → 保留
# public 静态资产 → 忽略
apps/web-admin/public/*.svg
apps/web-admin/public/icons/
apps/server/public/

# ────────────────────────────────────────
# 测试产物
# ────────────────────────────────────────
coverage/
.nyc_output/
test-results/

# ────────────────────────────────────────
# 文档（主动保留）
# ────────────────────────────────────────
# docs/ 包含设计文档和规则手册，是 Claude 理解
# 业务逻辑（CoC7、阿瓦隆、海龟汤规则）的关键上下文
# → 不忽略

# 仅忽略自动生成的 API 文档（如有）
docs/_build/
docs/api-generated/

# ────────────────────────────────────────
# IDE / 编辑器
# ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.iml

# ────────────────────────────────────────
# OS 文件
# ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ────────────────────────────────────────
# 其他 AI 工具上下文（对 Claude 无意义）
# ────────────────────────────────────────
.kimi/
.cursor/