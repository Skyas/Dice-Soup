{
  "name": "@dice-soup/server",
  "version": "0.1.0",
  "private": true,
  "description": "Dice&Soup main server — Fastify + OneBot + Database",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dice-soup/logger": "workspace:*",
    "@dice-soup/onebot-client": "workspace:*",
    "@dice-soup/security": "workspace:*",
    "@dice-soup/shared-types": "workspace:*",
    "@dice-soup/llm-router": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.1.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.32.1",
    "fastify": "^5.0.0",
    "pino": "^9.3.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.23.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
